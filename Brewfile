# Terminal setup — brew bundle --file=Brewfile

# Terminal + multiplexer
cask "ghostty"
brew "tmux"

# Prompt + zsh
brew "powerlevel10k"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"

# Nawigacja / wyszukiwanie
brew "fzf"
brew "zoxide"
brew "fd"
brew "ripgrep"

# Lepsze zamienniki coreutils
brew "eza"        # ls
brew "bat"        # cat
brew "btop"       # top
brew "git-delta"  # git diff pager

# Historia + pomoc
brew "atuin"      # Ctrl-R
brew "tlrc"       # tldr
